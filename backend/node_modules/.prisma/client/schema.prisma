generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Board {
  id             String   @id @default(uuid())
  slug           String   @unique
  name           String
  description    String?
  brandingConfig String   @default("{}")
  ownerId        String
  createdAt      DateTime @default(now())
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  status    String   @default("Stand By")
  tags      String   @default("[]")
  boardId   String
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  authorId  String?
  createdAt DateTime @default(now())
}

model Upvote {
  id          String   @id @default(uuid())
  postId      String
  userId      String?
  fingerprint String?
  createdAt   DateTime @default(now())
}
